{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "fasthtml-app",
	"main": "src/worker.py",
	"compatibility_date": "2026-03-27",
	"compatibility_flags": [
		"python_workers",
		"python_dedicated_snapshot"
	],
	"observability": { "enabled": true },
	"durable_objects": {
		"bindings": [
			{
				"name": "TENANTS",
				"class_name": "Tenant"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["Tenant"]
		}
	]
}
